# PostgreSQL
POSTGRES_USER=skypoint
POSTGRES_PASSWORD=skypoint_secret
POSTGRES_DB=skypoint_jobs

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=change_this_to_a_long_random_secret_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=http://localhost:5173

# Frontend — must match the host where backend is reachable from the browser
VITE_API_URL=http://localhost:8000/api/v1
